{
  "name": "portfolio-backend",
  "version": "1.0.0",
  "private": true,
  "description": "REST API backend for the Portfolio Management System.",
  "author": "Bharani",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "portfolio",
    "backend",
    "node",
    "express",
    "typescript",
    "mongodb",
    "mongoose",
    "rest-api",
    "swagger",
    "openapi",
    "zod"
  ],
  "scripts": {
    "prepare": "npm run type-check",
    "check:all": "npm run type-check && npm run lint && npm run build",
    "dev": "tsx watch src/app/server.ts",
    "build": "tsc",
    "start": "node dist/app/server.js",
    "start:prod": "npm run build && node dist/app/server.js",
    "clean": "rimraf dist",
    "rebuild": "npm run clean && npm run build",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run type-check && npm run lint && npm run format:check",
    "seed": "tsx src/seeders/seed.ts",
    "seed:auth": "tsx src/modules/auth/auth.seeder.ts",
    "seed:settings": "tsx src/modules/settings/settings.seeder.ts",
    "seed:hero": "tsx src/modules/hero/hero.seeder.ts",
    "seed:about": "tsx src/modules/about/about.seeder.ts",
    "seed:services": "tsx src/modules/services/services.seeder.ts",
    "seed:skills": "tsx src/modules/skills/skills.seeder.ts",
    "seed:experience": "tsx src/modules/experience/experience.seeder.ts",
    "seed:education": "tsx src/modules/education/education.seeder.ts",
    "seed:certifications": "tsx src/modules/certifications/certifications.seeder.ts",
    "seed:projects": "tsx src/modules/projects/projects.seeder.ts",
    "seed:testimonials": "tsx src/modules/testimonials/testimonials.seeder.ts",
    "seed:blogs": "tsx src/modules/blogs/blogs.seeder.ts",
    "seed:contact": "tsx src/modules/contact/contact.seeder.ts",
    "seed:build": "npm run build && node dist/seeders/seed.js",
    "seed:build:auth": "npm run build && node dist/modules/auth/auth.seeder.js",
    "seed:build:settings": "npm run build && node dist/modules/settings/settings.seeder.js",
    "seed:build:hero": "npm run build && node dist/modules/hero/hero.seeder.js",
    "seed:build:about": "npm run build && node dist/modules/about/about.seeder.js",
    "seed:build:services": "npm run build && node dist/modules/services/services.seeder.js",
    "seed:build:skills": "npm run build && node dist/modules/skills/skills.seeder.js",
    "seed:build:experience": "npm run build && node dist/modules/experience/experience.seeder.js",
    "seed:build:education": "npm run build && node dist/modules/education/education.seeder.js",
    "seed:build:certifications": "npm run build && node dist/modules/certifications/certifications.seeder.js",
    "seed:build:projects": "npm run build && node dist/modules/projects/projects.seeder.js",
    "seed:build:testimonials": "npm run build && node dist/modules/testimonials/testimonials.seeder.js",
    "seed:build:blogs": "npm run build && node dist/modules/blogs/blogs.seeder.js",
    "seed:build:contact": "npm run build && node dist/modules/contact/contact.seeder.js",
    "docker:build": "docker build -t portfolio-backend .",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:restart": "docker compose down && docker compose up --build",
    "docker:logs": "docker compose logs -f",
    "docker:ps": "docker ps",
    "docker:clean": "docker system prune -af"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cloudinary": "^1.41.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dayjs": "^1.11.21",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "fs-extra": "^11.3.6",
    "google-auth-library": "^10.7.0",
    "helmet": "^8.2.0",
    "http-status": "^2.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.7.0",
    "mongoose-paginate-v2": "^1.9.5",
    "multer": "^2.1.1",
    "multer-storage-cloudinary": "^4.0.0",
    "openapi-types": "^12.1.3",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^14.0.1",
    "zod": "^4.4.3",
    "zod-openapi": "^6.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mongoose-paginate-v2": "^1.6.4",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.2",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.8.4",
    "rimraf": "^6.1.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0"
  }
}
