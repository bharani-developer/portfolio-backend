{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "skipLibCheck": true,
    "sourceMap": true,

    "declaration": false,
    "declarationMap": false,

    "resolveJsonModule": true,

    "types": ["node"]
  },

  "include": ["src/**/*"],

  "exclude": ["node_modules", "dist"]
}
